# ============================================================================
# 04-multimodal-rag · LLM configuration template
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your key. The notebook loads `.env` at
# startup (shell environment wins over the file, same contract as 03-platform).
# `.env` is git-ignored; never commit a real key.
# ============================================================================

# --- required for generation (§8 and §11) ----------------------------------
OPENAI_API_KEY=sk-REPLACE-ME

# --- endpoint (leave unset for api.openai.com) ------------------------------
# OPENAI_BASE_URL=http://localhost:11434/v1     # e.g. Ollama / LM Studio / vLLM

# --- models (cheap defaults) -------------------------------------------------
# Other cheap options: gpt-5-nano, gpt-4.1-mini, gpt-4.1-nano, gpt-4o-mini
RAG_CHAT_MODEL=gpt-5-mini

# Judge defaults to the chat model. Setting a DIFFERENT (ideally stronger)
# model reduces self-preference bias in the LLM-as-judge metrics.
# RAG_JUDGE_MODEL=gpt-5-mini
